{
  "name": "kicktipp-bot",
  "description": "A simple but effective kicktipp bot using different strategies for tipping.",
  "author": "Andreas Schmid <service@aaschmid.de>",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aaschmid/kicktipp-bot"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "run-s test:format test:lint license:check test:unit test:build",
    "license:check": "license-checker-rseidelsohn --production --summary --unknown --onlyAllow \"Apache-2.0;BSD-2-Clause;MIT\"",
    "test:build": "run-s build",
    "test:format": "prettier --check .",
    "test:format:fix": "prettier --write .",
    "test:lint": "eslint .",
    "test:lint:fix": "eslint --fix .",
    "test:unit": "vitest run --typecheck",
    "test:ui": "vitest  --typecheck --ui",
    "test:watch": "vitest --typecheck"
  },
  "dependencies": {
    "@playwright/browser-chromium": "^1.59.1",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.59.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-istanbul": "^4.1.2",
    "eslint": "^10.3.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.2"
  },
  "prettier": {
    "printWidth": 140,
    "tabWidth": 2,
    "trailingComma": "all"
  }
}
